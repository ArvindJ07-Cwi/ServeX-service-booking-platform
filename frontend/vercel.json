{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://servex-service-booking-platform.onrender.com/api/:path*"
    },
    {
      "source": "/((?!assets|images|vite\\.svg|_redirects).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
