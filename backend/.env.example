PORT=5000
JWT_SECRET=your_strong_random_secret_here_min_32_chars
NODE_ENV=production

# ─── MySQL / PlanetScale / Railway Database ─────────────────────────────────
DB_HOST=your-mysql-host.render.com
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=service_booking_db
DB_PORT=3306

# ─── Frontend URL (used in emails, CORS, and reset links) ───────────────────
FRONTEND_URL=https://your-servex-app.onrender.com

# ─── Razorpay ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_live_secret

# ─── Email / SMTP ────────────────────────────────────────────────────────────
# Gmail: enable 2FA then generate App Password at https://myaccount.google.com/apppasswords
# NOTE: NO LEADING SPACES ON KEY NAMES — dotenv does NOT trim them!
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
FROM_NAME=ServeX
FROM_EMAIL=your_email@gmail.com

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
